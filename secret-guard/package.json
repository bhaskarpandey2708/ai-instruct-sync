  "description": "Guard against secrets leaking into AI agent rules, MCP configs, and prompts. Pre-commit / CI friendly. Zero runtime dependencies.",
  "type": "module",
  "bin": {
    "ai-secret-guard": "dist/cli.js",
    "secret-guard": "dist/cli.js"
  },
